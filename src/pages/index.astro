---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Zheng Zhu</title>
    <meta
      name="description"
      content="Zheng Zhu is a photographer based in Switzerland."
    />
  </head>

  <body>
    <main class="page">
      <header class="site-header">
        <a class="site-title" href="/">ZHENG ZHU</a>

        <div class="contact-menu">
          <button class="contact-trigger" type="button"> Contact </button>

          <div class="contact-dropdown">
            <a
              href="https://www.instagram.com/analogbyzheng/"
              target="_blank"
              rel="noreferrer"
            >
              Instagram
            </a>

            <a href="mailto:janzarchive23@gmail.com"> Email </a>
          </div>
        </div>
      </header>

      <section class="home">
        <div class="image-area">
          <img
            class="main-image"
            src="/images/home/cover.jpg"
            alt="Selected photograph by Zheng Zhu"
          />
        </div>

        <nav class="project-menu" aria-label="Selected projects">
          <a href="/projects/not-quite-leaving">Not Quite Leaving</a>
          <a href="/projects/under-a-passing-sun">Under a Passing Sun</a>
          <a href="/projects/how-shall-we-love-in-spring"
            >How Shall We Love in Spring</a
          >
        </nav>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    background: #fafafa;
  }

  :global(body) {
    margin: 0;
    min-height: 100vh;
    background: #fafafa;
    color: #222;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  :global(a:hover) {
    opacity: 0.45;
  }

  .page {
    min-height: 100vh;
    padding: 34px 42px;
  }

  .site-header {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 48px;
    align-items: start;
  }

  .site-title {
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .contact-menu {
    position: relative;
    justify-self: start;
    color: #555;
    z-index: 20;
  }

  .contact-trigger {
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: default;
  }

  .contact-dropdown {
    margin-top: 7px;

    display: flex;
    flex-direction: column;
    gap: 4px;

    color: #777;

    opacity: 0;
    transform: translateY(-2px);
    pointer-events: none;

    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .contact-menu:hover .contact-dropdown,
  .contact-menu:focus-within .contact-dropdown {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .contact-dropdown a {
    color: #777;
    white-space: nowrap;
  }

  .contact-dropdown a:hover,
  .contact-trigger:hover {
    opacity: 0.45;
  }

  .home {
    min-height: calc(100vh - 92px);
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: 48px;
    align-items: center;
  }

  .image-area {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 160px);
    padding-left: 180px;
  }

  .main-image {
    display: block;
    width: auto;
    height: auto;
    max-width: min(72vw, 980px);
    max-height: 72vh;
    object-fit: contain;
  }

  .project-menu {
    align-self: start;
    margin-top: 18vh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 7px;
    color: #333;
  }

  .project-menu a {
    font-size: 13px;
  }

  @media (max-width: 860px) {
    .page {
      padding: 24px 22px;
    }

    .site-header {
      grid-template-columns: 1fr auto;
      gap: 24px;
    }

    .home {
      min-height: auto;
      grid-template-columns: 1fr;
      gap: 36px;
      padding-top: 84px;
    }

    .image-area {
      min-height: auto;
      padding-left: 0;
    }

    .main-image {
      max-width: 88vw;
      max-height: 64vh;
    }

    .project-menu {
      margin-top: 0;
      align-items: center;
      justify-self: center;
      text-align: center;
    }
  }
</style>
